# Environment Configuration - Copy to .env and fill in your values

PORT=3001
NODE_ENV=development

# PostgreSQL Configuration
# IMPORTANT: Set this in Render dashboard under "Environment" tab
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://username:password@host:port/database_name

# Optional: Local PostgreSQL connection (if not using DATABASE_URL)
# Uncomment these if running PostgreSQL locally
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=invoice_db

# Application Settings
# EXAMPLE_API_KEY=your-api-key-here
# EXAMPLE_FEATURE_FLAG=true
